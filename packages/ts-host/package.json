{
  "name": "@ai37/agent-host",
  "version": "0.1.0-alpha.20",
  "description": "AI37 agent host: Express + A2A + AG-UI + JWT-guard (поверх @ai37/agent-sdk)",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./relay": {
      "types": "./dist/relay/index.d.ts",
      "import": "./dist/relay/index.js",
      "require": "./dist/relay/index.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "relay": [
        "./dist/relay/index.d.ts"
      ]
    }
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run lint && npm run test && npm run build",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@ag-ui/core": "^0.0.57",
    "@ag-ui/encoder": "^0.0.57",
    "@ai37/a2ui-catalog-schemas": "^0.4.0",
    "@langfuse/otel": "^5.6.0",
    "@langfuse/tracing": "^5.6.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "express": "^4.21.2",
    "uuid": "^14.0.0"
  },
  "optionalDependencies": {
    "@langfuse/langchain": "^5.6.0"
  },
  "peerDependencies": {
    "@ai37/agent-sdk": ">=0.1.0-alpha.5",
    "@langchain/core": ">=0.3.8",
    "@langchain/openai": ">=1.0.0",
    "@modelcontextprotocol/sdk": ">=1.26.0",
    "zod": "^3.25 || ^4.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "@langchain/openai": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai37/agent-sdk": "file:../ts",
    "@langchain/core": "^1.1.0",
    "@langchain/openai": "^1.4.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3",
    "deepagents": "^1.10.2",
    "@types/express": "^4.17.21",
    "@types/node": "^24.11.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
